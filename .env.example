# Port the gateway listens on
PORT=3000

# The upstream API this gateway proxies requests to
BACKEND_URL=http://localhost:4000

# Leave unset to use in-memory storage (single instance, local dev).
# Set to enable distributed rate limiting shared across instances:
# REDIS_URL=redis://localhost:6379

# Which algorithm to use: "token-bucket" or "sliding-window"
RATE_LIMIT_ALGORITHM=token-bucket

# Token bucket settings
BUCKET_CAPACITY=20
BUCKET_REFILL_RATE=5

# Sliding window settings
WINDOW_MAX_REQUESTS=100
WINDOW_SECONDS=60

{
  "name": "rate-limit-gateway",
  "version": "1.0.0",
  "description": "A distributed API rate limiter and reverse proxy gateway supporting token bucket and sliding window algorithms, backed by Redis for multi-instance consistency.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "mock-backend": "ts-node-dev --respawn --transpile-only src/mockBackend.ts",
    "test": "jest --runInBand",
    "loadtest": "node loadtest/run.js"
  },
  "keywords": ["rate-limiter", "api-gateway", "distributed-systems", "redis"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "http-proxy-middleware": "^3.0.0",
    "ioredis": "^5.4.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/jest": "^29.5.12",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "autocannon": "^7.15.0"
  }
}
